generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model categorias_medicamento {
  id           Int            @id @default(autoincrement())
  nombre       String         @unique @db.VarChar(100)
  medicamentos medicamentos[]
}

model citas {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paciente_id        String             @db.Uuid
  medico_id          String             @db.Uuid
  fecha_hora         DateTime           @db.Timestamp(6)
  duracion_minutos   Int                @default(30) @db.SmallInt
  estado             estado_cita        @default(PENDIENTE)
  motivo             String?
  notas_medico       String?
  reagendada_de      String?            @db.Uuid
  cancelada_por      String?            @db.Uuid
  motivo_cancelacion String?
  creado_en          DateTime           @default(now()) @db.Timestamp(6)
  actualizado_en     DateTime           @default(now()) @db.Timestamp(6)
  usuarios           usuarios?          @relation(fields: [cancelada_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  medicos            medicos            @relation(fields: [medico_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pacientes          pacientes          @relation(fields: [paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  citas              citas?             @relation("citasTocitas", fields: [reagendada_de], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_citas        citas[]            @relation("citasTocitas")
  historial_medico   historial_medico[]

  @@unique([medico_id, fecha_hora])
  @@index([estado], map: "idx_citas_estado")
  @@index([medico_id, fecha_hora], map: "idx_citas_medico_fecha")
  @@index([paciente_id], map: "idx_citas_paciente")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model disponibilidad_medico {
  id            Int      @id @default(autoincrement())
  medico_id     String   @db.Uuid
  dia_semana    Int      @db.SmallInt
  hora_inicio   DateTime @db.Time(6)
  hora_fin      DateTime @db.Time(6)
  duracion_cita Int      @default(30) @db.SmallInt
  activo        Boolean  @default(true)
  medicos       medicos  @relation(fields: [medico_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([medico_id, dia_semana, hora_inicio])
}

model especialidades {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique @db.VarChar(100)
  descripcion String?
  medicos     medicos[]
  turnos      turnos[]
}

model historial_medico {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paciente_id   String    @db.Uuid
  cita_id       String?   @db.Uuid
  medico_id     String    @db.Uuid
  diagnostico   String?
  tratamiento   String?
  observaciones String?
  creado_en     DateTime  @default(now()) @db.Timestamp(6)
  citas         citas?    @relation(fields: [cita_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  medicos       medicos   @relation(fields: [medico_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pacientes     pacientes @relation(fields: [paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recetas       recetas[]
}

model inventario_medicamentos {
  id             Int                        @id @default(autoincrement())
  medicamento_id Int
  sede_id        Int
  stock_actual   Int                        @default(0)
  stock_minimo   Int                        @default(10)
  disponibilidad disponibilidad_medicamento @default(DISPONIBLE)
  precio         Decimal?                   @db.Decimal(10, 2)
  actualizado_en DateTime                   @default(now()) @db.Timestamp(6)
  medicamentos   medicamentos               @relation(fields: [medicamento_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sedes          sedes                      @relation(fields: [sede_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([medicamento_id, sede_id])
}

model medicamentos {
  id                      Int                       @id @default(autoincrement())
  nombre_comercial        String                    @db.VarChar(150)
  nombre_generico         String?                   @db.VarChar(150)
  categoria_id            Int?
  descripcion             String?
  indicaciones            String?
  contraindicaciones      String?
  presentacion            String?                   @db.VarChar(100)
  requiere_receta         Boolean                   @default(true)
  activo                  Boolean                   @default(true)
  creado_en               DateTime                  @default(now()) @db.Timestamp(6)
  inventario_medicamentos inventario_medicamentos[]
  categorias_medicamento  categorias_medicamento?   @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recetas                 recetas[]

  @@index([nombre_comercial, nombre_generico], map: "idx_medicamentos_nombre")
}

model medicos {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuario_id            String                  @db.Uuid
  especialidad_id       Int
  numero_registro       String                  @unique @db.VarChar(50)
  consultorio           String?                 @db.VarChar(20)
  activo                Boolean                 @default(true)
  creado_en             DateTime                @default(now()) @db.Timestamp(6)
  citas                 citas[]
  disponibilidad_medico disponibilidad_medico[]
  historial_medico      historial_medico[]
  especialidades        especialidades          @relation(fields: [especialidad_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios              usuarios                @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  turnos                turnos[]
}

model notificaciones {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuario_id    String   @db.Uuid
  titulo        String   @db.VarChar(200)
  mensaje       String
  tipo          String   @db.VarChar(50)
  leida         Boolean  @default(false)
  referencia_id String?  @db.Uuid
  creado_en     DateTime @default(now()) @db.Timestamp(6)
  usuarios      usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuario_id, leida], map: "idx_notificaciones_usuario")
}

model pacientes {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuario_id       String             @db.Uuid
  fecha_nacimiento DateTime?          @db.Date
  tipo_sangre      String?            @db.VarChar(5)
  numero_documento String?            @unique @db.VarChar(20)
  tipo_documento   String?            @default("CC") @db.VarChar(20)
  eps              String?            @db.VarChar(100)
  alergias         String?
  antecedentes     String?
  creado_en        DateTime           @default(now()) @db.Timestamp(6)
  citas            citas[]
  historial_medico historial_medico[]
  usuarios         usuarios           @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  turnos           turnos[]
}

model recetas {
  id               Int              @id @default(autoincrement())
  historial_id     String           @db.Uuid
  medicamento_id   Int
  dosis            String?          @db.VarChar(100)
  frecuencia       String?          @db.VarChar(100)
  duracion_dias    Int?             @db.SmallInt
  observaciones    String?
  historial_medico historial_medico @relation(fields: [historial_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  medicamentos     medicamentos     @relation(fields: [medicamento_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model refresh_tokens {
  id         Int      @id @default(autoincrement())
  usuario_id String   @db.Uuid
  token      String   @unique
  expira_en  DateTime @db.Timestamp(6)
  revocado   Boolean  @default(false)
  creado_en  DateTime @default(now()) @db.Timestamp(6)
  usuarios   usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model sedes {
  id                      Int                       @id @default(autoincrement())
  nombre                  String                    @db.VarChar(150)
  direccion               String?
  ciudad                  String?                   @db.VarChar(100)
  inventario_medicamentos inventario_medicamentos[]
}

model turnos {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paciente_id     String          @db.Uuid
  medico_id       String?         @db.Uuid
  especialidad_id Int?
  numero_turno    Int             @db.SmallInt
  tipo            tipo_turno      @default(NORMAL)
  estado          estado_turno    @default(EN_ESPERA)
  posicion_cola   Int?            @db.SmallInt
  llamado_en      DateTime?       @db.Timestamp(6)
  atendido_en     DateTime?       @db.Timestamp(6)
  fecha           DateTime        @default(dbgenerated("CURRENT_DATE")) @db.Date
  creado_en       DateTime        @default(now()) @db.Timestamp(6)
  especialidades  especialidades? @relation(fields: [especialidad_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  medicos         medicos?        @relation(fields: [medico_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pacientes       pacientes       @relation(fields: [paciente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([fecha, numero_turno, medico_id])
  @@index([fecha, estado], map: "idx_turnos_fecha_estado")
  @@index([paciente_id], map: "idx_turnos_paciente")
}

model usuarios {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre         String           @db.VarChar(100)
  apellido       String           @db.VarChar(100)
  email          String           @unique @db.VarChar(150)
  password_hash  String
  rol            rol_usuario      @default(PACIENTE)
  telefono       String?          @db.VarChar(20)
  activo         Boolean          @default(true)
  creado_en      DateTime         @default(now()) @db.Timestamp(6)
  actualizado_en DateTime         @default(now()) @db.Timestamp(6)
  citas          citas[]
  medicos        medicos[]
  notificaciones notificaciones[]
  pacientes      pacientes[]
  refresh_tokens refresh_tokens[]
}

enum disponibilidad_medicamento {
  DISPONIBLE
  STOCK_BAJO
  AGOTADO
}

enum estado_cita {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  POSPUESTA
  COMPLETADA
}

enum estado_turno {
  EN_ESPERA
  EN_CONSULTA
  ATENDIDO
  CANCELADO
}

enum rol_usuario {
  PACIENTE
  MEDICO
  ADMIN
  RECEPCIONISTA
}

enum tipo_turno {
  NORMAL
  PRIORITARIO
  URGENTE
}
