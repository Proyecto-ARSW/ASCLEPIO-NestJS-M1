# node-linker=hoisted: pnpm crea node_modules plano en lugar del virtual store con symlinks.
# Azure App Service extrae el ZIP y NO preserva symlinks, lo que rompe la estructura
# predeterminada de pnpm (.pnpm/ + symlinks). Con hoisted, la estructura es equivalente
# a la de npm/yarn y Azure puede resolverla sin problemas.
node-linker=hoisted
shamefully-hoist=true
