# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000

# ─── Base de datos (requerida) ────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asclepio?schema=public

# ─── JWT (requerido) ──────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Genera uno seguro con: openssl rand -base64 48
JWT_SECRET=cambia_este_secreto_por_uno_seguro_de_al_menos_32_chars
JWT_EXPIRES_IN=8h

# ─── Integración ISISvoice ─────────────────────────────────────────────────────
ISISVOICE_BASE_URL=http://localhost:8000