# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000

# ─── Base de datos (requerida) ────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asclepio?schema=public

# ─── JWT (requerido) ──────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Genera uno seguro con: openssl rand -base64 48
JWT_SECRET=cambia_este_secreto_por_uno_seguro_de_al_menos_32_chars
JWT_EXPIRES_IN=8h

# ─── Cifrado de campos PHI (opcional en desarrollo, requerido en producción) ──
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# En Azure App Service configurar como Application Setting, NUNCA en .env commiteado.
FIELD_ENCRYPTION_KEY=cambia_este_valor_por_64_hex_chars_aleatorios_minimo_32_chars
FIELD_ENCRYPTION_SALT=asclepio-v1-prod
# ─── Integración ISISvoice ─────────────────────────────────────────────────────
ISISVOICE_BASE_URL=http://localhost:8000
